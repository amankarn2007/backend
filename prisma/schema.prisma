generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model User {
  id                    String      @default(uuid())     @id
  username              String
  email                 String      @unique
  password              String
  verified              Boolean     @default(false)
  otps                  Otp[]       //not an array
  session               Session[]   //this is not an array, just a refrense
}

model Otp {
  id                    String      @default(uuid())      @id
  otpHash               String
  timestamps            Boolean
  email                 String

  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  userId                String
  user                  User        @relation(fields: [userId], references: [id])
}

model Session {
  id                    String      @default(uuid())      @id
  userId                String
  user                  User        @relation(fields: [userId], references: [id])
  refreshTokenHash      String
  ip                    String
  userAgent             String
  revoked               Boolean     @default(false)
}